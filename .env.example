# Supabase (required)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Web Push / PWA (optional - for workflow handoff notifications)
# Generate VAPID keys: npx web-push generate-vapid-keys
# Add public key here; add both keys to Supabase: supabase secrets set VAPID_PUBLIC_KEY=... VAPID_PRIVATE_KEY=...
VITE_VAPID_PUBLIC_KEY=

# Dev login (optional - for local testing without credentials)
# Only active when running dev server (import.meta.env.DEV). Add to .env.local.
# Also set for Edge Function: supabase secrets set DEV_LOGIN_SECRET=your-secret
VITE_DEV_LOGIN_SECRET=
