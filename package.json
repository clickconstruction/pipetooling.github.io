{
  "name": "pipetooling",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "overrides": {
    "sourcemap-codec": "npm:@jridgewell/sourcemap-codec@^1.5.0",
    "source-map": "^0.7.6",
    "glob": "^13.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "analyze": "tsc -b && ANALYZE=1 vite build",
    "preview": "vite preview",
    "gen-types:local": "supabase gen types typescript --local > src/types/database.ts",
    "gen-types:linked": "supabase gen types typescript --linked > src/types/database.ts",
    "gen-debit-card-nickname-sql": "node scripts/generate-debit-card-nickname-sql.mjs",
    "check:timezone": "node scripts/check-app-calendar-tz.mjs",
    "test": "vitest run",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "typecheck": "tsc -b",
    "format": "prettier --write src",
    "format:check": "prettier --check src"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@geoman-io/leaflet-geoman-free": "^2.19.3",
    "@supabase/supabase-js": "^2.47.10",
    "@tanstack/react-virtual": "^3.13.18",
    "@tiptap/extension-link": "^3.22.4",
    "@tiptap/pm": "^3.22.4",
    "@tiptap/react": "^3.22.4",
    "@tiptap/starter-kit": "^3.22.4",
    "@turf/turf": "^7.3.5",
    "@xyflow/react": "^12.10.2",
    "dagre": "^0.8.5",
    "exceljs": "^4.4.0",
    "jspdf": "^4.1.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.577.0",
    "marked": "^15.0.12",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^6.28.0",
    "recharts": "^2.15.4",
    "signature_pad": "^5.1.3"
  },
  "devDependencies": {
    "@types/dagre": "^0.7.54",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "rollup-plugin-visualizer": "^5.14.0",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.60.0",
    "vite": "^5.4.10",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^2.1.9",
    "workbox-core": "^7.4.0",
    "workbox-precaching": "^7.4.0",
    "workbox-routing": "^7.4.0",
    "workbox-window": "^7.4.0"
  }
}
